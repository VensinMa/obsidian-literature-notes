# Zotero API 配置
# 获取 API Key: https://www.zotero.org/settings/keys

# 你的 Zotero 用户 ID（数字）
export ZOTERO_USER_ID="你的用户ID"

# 你的 Zotero API Key
export ZOTERO_API_KEY="你的APIK...
# Obsidian Vault 路径
export OBSIDIAN_VAULT_PATH="/path/to/your/obsidian/vault"

# 文献笔记目录
export OBSIDIAN_LITERATURE_PATH="$OBSIDIAN_VAULT_PATH/文献阅读笔记"
